#!/usr/bin/env sh
# Verify build artifacts are in sync with src/.
# Mutating the index from within pre-commit is unsafe (the outer commit holds
# the index lock), so this hook only verifies — if anything drifts, run
# `npm run build` and stage the results before re-committing.
set -e

npm run build --silent

ARTIFACT_PATHS="agents/ skills/ src/hooks/ hooks/ commands/ plugins/doc-detective/ .claude-plugin/marketplace.json gemini-extension.json qwen-extension.json"

DRIFTED_TRACKED="$(git diff --name-only -- $ARTIFACT_PATHS)"
DRIFTED_UNTRACKED="$(git ls-files --others --exclude-standard -- $ARTIFACT_PATHS)"

if [ -n "$DRIFTED_TRACKED" ] || [ -n "$DRIFTED_UNTRACKED" ]; then
  echo ""
  echo "ERROR: Build artifacts are out of date with src/."
  echo "       Run 'npm run build' and stage the results, then re-commit."
  echo ""
  echo "Drifted paths:"
  {
    printf '%s\n' "$DRIFTED_TRACKED"
    printf '%s\n' "$DRIFTED_UNTRACKED"
  } | sed '/^$/d; s/^/  /'
  exit 1
fi
