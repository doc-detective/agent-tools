{
  "branches": ["main"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "releaseRules": [{ "type": "perf", "release": false }]
      }
    ],
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      { "changelogFile": "CHANGELOG.md" }
    ],
    [
      "@semantic-release/npm",
      { "npmPublish": false }
    ],
    [
      "@semantic-release/exec",
      { "prepareCmd": "npm run build:no-scripts" }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "package.json",
          "package-lock.json",
          ".claude-plugin/marketplace.json",
          ".cursor-plugin/marketplace.json",
          "gemini-extension.json",
          "qwen-extension.json",
          "agents/**",
          "skills/**",
          "commands/**",
          "hooks/**",
          "src/skills/**",
          "src/agents/**",
          "src/hooks/**",
          "plugins/doc-detective/**",
          "plugins/doc-detective/.claude-plugin/plugin.json",
          "plugins/doc-detective/.codex-plugin/plugin.json",
          "plugins/doc-detective/.cursor-plugin/plugin.json",
          "plugins/doc-detective/.mcp.json"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
